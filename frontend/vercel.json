{
  "framework": "angular",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/mform-upload/browser",
  "installCommand": "npm install",
  "git": {
    "ignoreBuildStep": "git log -1 --pretty=%B | grep -q '\\[skip ci\\]' || git diff --quiet HEAD^ HEAD -- ."
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
